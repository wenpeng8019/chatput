<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Chatput" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/chatput_accent</item>
        <item name="colorPrimaryVariant">@color/chatput_accent_strong</item>
        <item name="colorSecondary">@color/chatput_accent</item>
        <item name="colorSurface">@color/chatput_surface</item>
        <item name="android:colorBackground">@color/chatput_bg</item>
        <item name="android:windowBackground">@color/chatput_bg</item>
        <item name="colorOnPrimary">@color/chatput_on_accent</item>
        <item name="colorOnSurface">@color/chatput_text_primary</item>
        <item name="colorOnBackground">@color/chatput_text_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/chatput_bg</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="materialButtonStyle">@style/Chatput.Button</item>
    </style>

    <style name="Chatput.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/chatput_surface_alt</item>
        <item name="android:textColor">@color/chatput_text_primary</item>
        <item name="rippleColor">@color/chatput_accent_soft</item>
    </style>

    <style name="Chatput.ActionButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/chatput_line</item>
        <item name="backgroundTint">@color/chatput_surface</item>
        <item name="android:textColor">@color/chatput_text_primary</item>
        <item name="android:minHeight">42dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Smooth/continuous corner shape (API 31+), falls back to circular on older -->
    <style name="ShapeAppearance.Chatput.Smooth" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/composer_corner_radius</item>
    </style>

    <style name="Chatput.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">22dp</item>
        <item name="backgroundTint">@color/chatput_accent</item>
        <item name="android:textColor">@color/chatput_on_accent</item>
        <item name="android:textSize">17sp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

</resources>
