<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_recent_device"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/space_4"
    android:paddingTop="@dimen/space_3"
    android:paddingEnd="14dp"
    android:paddingBottom="@dimen/space_3">

    <ImageView
        android:id="@+id/device_delete"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:contentDescription="删除历史连接"
        android:focusable="true"
        android:src="@drawable/ic_delete"
        android:tint="@color/chatput_text_secondary" />

    <TextView
        android:id="@+id/device_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="设备"
        android:textColor="@color/chatput_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/device_reconnect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="重新连接"
        android:textColor="@color/chatput_accent"
        android:textSize="13sp" />

    <ProgressBar
        android:id="@+id/device_reconnect_loading"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/chatput_accent"
        android:visibility="gone" />

</LinearLayout>
