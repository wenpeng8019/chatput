<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/chatput_bg">

	<com.google.android.material.card.MaterialCardView
		android:id="@+id/header_card"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="@dimen/screen_margin"
		android:layout_marginTop="20dp"
		android:layout_marginEnd="@dimen/screen_margin"
		app:cardBackgroundColor="@color/chatput_surface"
		app:cardCornerRadius="@dimen/radius_panel"
		app:cardElevation="0dp"
		app:strokeColor="@color/chatput_line"
		app:strokeWidth="1dp"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent">

		<LinearLayout
			android:id="@+id/header_content"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:paddingStart="@dimen/space_4"
			android:paddingTop="@dimen/screen_margin"
			android:paddingEnd="@dimen/screen_margin"
			android:paddingBottom="@dimen/screen_margin">

			<TextView
				android:id="@+id/app_label"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Chatput"
				android:textColor="@color/chatput_accent"
				android:textSize="12sp"
				android:textStyle="bold" />

			<TextView
				android:id="@+id/header_title"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="10dp"
				android:text="把桌面输入做得更自然"
				android:textColor="@color/chatput_text_primary"
				android:textSize="24sp"
				android:textStyle="bold" />

			<TextView
				android:id="@+id/header_description"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:lineSpacingExtra="2dp"
				android:text="连接后，当前聚焦窗口会自动成为会话。"
				android:textColor="@color/chatput_text_secondary"
				android:textSize="14sp" />

			<TextView
				android:id="@+id/status"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dp"
				android:background="@drawable/bg_status_chip_idle"
				android:paddingHorizontal="12dp"
				android:paddingVertical="7dp"
				android:text="未连接"
				android:textColor="@color/chatput_status_idle_text"
				android:textSize="13sp"
				android:textStyle="bold" />

		</LinearLayout>

	</com.google.android.material.card.MaterialCardView>

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/list"
		android:layout_width="0dp"
		android:layout_height="0dp"
		android:clipToPadding="false"
		android:paddingStart="@dimen/space_4"
		android:paddingTop="14dp"
		android:paddingEnd="@dimen/space_4"
		android:paddingBottom="110dp"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintTop_toTopOf="parent" />

	<LinearLayout
		android:id="@+id/recent_container"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="36dp"
		android:layout_marginEnd="36dp"
		android:layout_marginBottom="@dimen/space_6"
		android:orientation="vertical"
		android:visibility="gone"
		app:layout_constraintBottom_toTopOf="@id/empty"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent">

		<TextView
			android:id="@+id/recent_label"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginStart="2dp"
			android:layout_marginBottom="10dp"
			android:text="历史连接"
			android:textColor="@color/chatput_text_tertiary"
			android:textSize="13sp" />

	</LinearLayout>

	<TextView
		android:id="@+id/empty"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginStart="36dp"
		android:layout_marginEnd="36dp"
		android:layout_marginBottom="16dp"
		android:background="@drawable/bg_status_chip_idle"
		android:gravity="center"
		android:includeFontPadding="false"
		android:lineHeight="17sp"
		android:paddingHorizontal="22dp"
		android:paddingVertical="13dp"
		android:text="扫码连接你的桌面"
		android:textColor="@color/chatput_text_secondary"
		android:textSize="15sp"
		app:layout_constraintBottom_toTopOf="@id/fab_scan"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent" />

	<com.google.android.material.floatingactionbutton.FloatingActionButton
		android:id="@+id/fab_scan"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginBottom="24dp"
		android:contentDescription="扫码配对"
		android:src="@drawable/ic_scan"
		app:backgroundTint="@color/chatput_accent"
		app:tint="@color/chatput_on_accent"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
